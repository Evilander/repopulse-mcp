# RepoPulse optional environment overrides. Copy to .env and edit locally.

# Enable local embeddings (requires the `[embeddings]` extra).
# REPOPULSE_EMBEDDINGS=1

# Override the default embedding model.
# Default: BAAI/bge-small-en-v1.5 (~90 MB, supported by fastembed).
# Alternatives: nomic-ai/nomic-embed-text-v1.5 (~280 MB, longer context).
# REPOPULSE_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5

# Disable ANSI color in CLI output (community-standard NO_COLOR also honored).
# REPOPULSE_ACCESSIBILITY=1
